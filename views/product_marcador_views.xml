<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_marcador_list" model="ir.ui.view">
        <field name="name">product.marcador.list</field>
        <field name="model">product.marcador</field>
        <field name="arch" type="xml">
            <list string="Marcadores de Produto" editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="product_count"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_product_marcador_form" model="ir.ui.view">
        <field name="name">product.marcador.form</field>
        <field name="model">product.marcador</field>
        <field name="arch" type="xml">
            <form string="Marcador de Produto">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Ex.: Promoção, Frágil, Novidade..."/>
                        </h1>
                    </div>
                    <group>
                        <field name="color" widget="color_picker"/>
                        <field name="active"/>
                    </group>
                    <notebook>
                        <page string="Produtos" name="produtos">
                            <field name="product_tmpl_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="default_code"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_product_marcador_search" model="ir.ui.view">
        <field name="name">product.marcador.search</field>
        <field name="model">product.marcador</field>
        <field name="arch" type="xml">
            <search string="Marcadores de Produto">
                <field name="name"/>
                <filter string="Arquivados" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_product_marcador" model="ir.actions.act_window">
        <field name="name">Marcadores de Produto</field>
        <field name="res_model">product.marcador</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crie seu primeiro marcador de produto
            </p>
            <p>
                Marcadores ajudam a classificar e filtrar produtos no Inventário.
            </p>
        </field>
    </record>

    <menuitem id="menu_product_marcador"
              name="Marcadores de Produto"
              parent="stock.menu_stock_config_settings"
              action="action_product_marcador"
              sequence="60"/>

</odoo>
