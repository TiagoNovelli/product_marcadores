<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_view_marcadores" model="ir.ui.view">
        <field name="name">product.template.form.marcadores</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="marcador_ids"
                       widget="many2many_tags"
                       options="{'color_field': 'color', 'no_create_edit': True}"/>
            </xpath>
        </field>
    </record>

    <record id="product_template_search_view_marcadores" model="ir.ui.view">
        <field name="name">product.template.search.marcadores</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <field name="marcador_ids" string="Marcadores"/>
                <separator/>
                <filter string="Marcadores" name="groupby_marcador" context="{'group_by': 'marcador_ids'}"/>
            </xpath>
        </field>
    </record>

</odoo>
